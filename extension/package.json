{
  "name": "aireviewer",
  "displayName": "AiReviewer",
  "description": "AI-powered root cause and code intelligence tool",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aireviewer.analyzeError",
        "title": "AiReviewer: Analyze Error"
      },
      {
        "command": "aireviewer.viewReports",
        "title": "AiReviewer: View Reports"
      },
      {
        "command": "aireviewer.checkRemote",
        "title": "AiReviewer: Check Remote Changes"
      },
      {
        "command": "aireviewer.checkPush",
        "title": "AiReviewer: Check Push Safety"
      },
      {
        "command": "aireviewer.fetchChanges",
        "title": "AiReviewer: Fetch Changes"
      },
      {
        "command": "aireviewer.pullChanges",
        "title": "AiReviewer: Pull Changes"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aireviewer-sidebar",
          "title": "AiReviewer",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "aireviewer-sidebar": [
        {
          "type": "webview",
          "id": "aireviewer.sidebar",
          "name": "Chat"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "overrides": {
    "diff": "^8.0.2",
    "serialize-javascript": "^7.0.3"
  },
  "dependencies": {
    "axios": "^1.13.6"
  }
}